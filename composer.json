{
    "name": "dylanoazen/teste-ebanx",
    "description": "EBANX take-home assignment: in-memory banking API.",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "react/http": "^1.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php public/server.php",
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
