{
    "name": "dylanoazen/teste-ebanx",
    "description": "EBANX take-home assignment: in-memory banking API.",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "react/http": "^1.9"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "start": "php public/server.php",
        "test": "phpunit",
        "lint": "php-cs-fixer fix --dry-run --diff",
        "lint:fix": "php-cs-fixer fix"

    },
    "config": {
        "sort-packages": true
    }
}
